{
  "name": "fin",
  "private": true,
  "workspaces": ["frontend", "shared"],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && .venv/bin/uvicorn main:app --reload --port 8000",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern .venv",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.app.json && tsc --noEmit -p shared/tsconfig.json"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}