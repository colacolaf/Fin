# Fin — Environment Variables
# Copy to .env and fill in values. Never commit real secrets.

# ── Core ──────────────────────────────────────────────────
# Deployment environment: local | production
FIN_ENV=local

# Path to data directory (SQLite DB, memory, user profiles)
DATA_DIR=./data

# SQLite database file path
DB_PATH=./data/fin.db

# ── Auth ──────────────────────────────────────────────────
# JWT signing secret. Generate: python3 -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=change-me-to-a-random-secret

# Enable/disable authentication. Set false for local single-user dev.
# Required: false (local), true (production)
AUTH_ENABLED=false

# ── Ollama (Local LLM) ────────────────────────────────────
# Ollama API host. Default serves locally.
# Required: true
OLLAMA_HOST=http://localhost:11434

# Model to pull and use. Options: mistral:7b, qwen2.5:32b, deepseek-r1:70b
# Required: true
OLLAMA_MODEL=mistral:7b

# ── Brokerage & Data APIs ─────────────────────────────────
# Alpaca Markets API (trading + portfolio data)
# Required: true (for live portfolio sync)
# Get keys: https://app.alpaca.markets/
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here

# Plaid API (banking data for Debt Agent)
# Required: false (only for Debt Agent features)
# Get keys: https://dashboard.plaid.com/
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here

# Finnhub API (market research data)
# Required: false (only for Research Agent features)
# Get keys: https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_key_here

# ── Redis (Optional) ──────────────────────────────────────
# Redis connection URL for rate limiting. Falls back to in-memory if unset.
# Required: false
# REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────
# Allowed origins for CORS. Comma-separated.
# Required: true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173